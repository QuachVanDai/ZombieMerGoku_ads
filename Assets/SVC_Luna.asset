            u_xlat27 = clamp(u_xlat27, 0.0, 1.0);\n    u_xlat0.x = dot(_WorldSpaceLightPos0.xyz,
            u_xlat0.xyz);\n    u_xlat0.x = clamp(u_xlat0.x, 0.0, 1.0);\n    u_xlat9.x
            = (-_Glossiness) + 1.0;\n    u_xlat18 = u_xlat9.x * u_xlat9.x;\n    u_xlat18
