            = u_xlat16_3.xyz * u_xlat16_5.xyz;\n    SV_Target0.xyz = u_xlat16_4.xyz
            * u_xlat16_8.xyz + u_xlat16_3.xyz;\n    SV_Target0.w = 1.0;\n    return;\n}\n\n"
