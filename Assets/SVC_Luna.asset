          VertexProgram: "\n#version 300 es\n\n#define HLSLCC_ENABLE_UNIFORM_BUFFERS
            0\n#if HLSLCC_ENABLE_UNIFORM_BUFFERS\n#define UNITY_UNIFORM\n#else\n#define
            UNITY_UNIFORM uniform\n#endif\n#define UNITY_SUPPORTS_UNIFORM_LOCATION
            0\n#if UNITY_SUPPORTS_UNIFORM_LOCATION\n#define UNITY_LOCATION(x) layout(location
            = x)\n#define UNITY_BINDING(x) layout(binding = x, std140)\n#else\n#define
            UNITY_LOCATION(x)\n#define UNITY_BINDING(x) layout(std140)\n#endif\nuniform
            \tvec4 hlslcc_mtx4x4unity_ObjectToWorld[4];\nuniform \tvec4 hlslcc_mtx4x4unity_MatrixVP[4];\nuniform
            \tint unity_StereoEyeIndex;\nuniform \tfloat _Rotation;\nuniform \tint
            _MirrorOnBack;\nuniform \tint _ImageType;\nuniform \tint _Layout;\nin
            highp vec4 in_POSITION0;\nout highp vec3 vs_TEXCOORD0;\nout highp vec2
            vs_TEXCOORD1;\nout highp vec4 vs_TEXCOORD2;\nvec4 u_xlat0;\nint u_xlati0;\nvec4
            u_xlat1;\nbool u_xlatb1;\nvec4 u_xlat2;\nfloat u_xlat3;\nvoid main()\n{\n   
            u_xlat0.x = _Rotation * 0.0174532942;\n    u_xlat1.x = cos(u_xlat0.x);\n   
            u_xlat0.x = sin(u_xlat0.x);\n    u_xlat2.x = (-u_xlat0.x);\n    u_xlat2.y
            = u_xlat1.x;\n    u_xlat2.z = u_xlat0.x;\n    u_xlat0.x = dot(u_xlat2.zy,
            in_POSITION0.xz);\n    u_xlat3 = dot(u_xlat2.yx, in_POSITION0.xz);\n   
            u_xlat1 = in_POSITION0.yyyy * hlslcc_mtx4x4unity_ObjectToWorld[1];\n   
            u_xlat1 = hlslcc_mtx4x4unity_ObjectToWorld[0] * vec4(u_xlat3) + u_xlat1;\n   
            u_xlat0 = hlslcc_mtx4x4unity_ObjectToWorld[2] * u_xlat0.xxxx + u_xlat1;\n   
            u_xlat0 = u_xlat0 + hlslcc_mtx4x4unity_ObjectToWorld[3];\n    u_xlat1
            = u_xlat0.yyyy * hlslcc_mtx4x4unity_MatrixVP[1];\n    u_xlat1 = hlslcc_mtx4x4unity_MatrixVP[0]
            * u_xlat0.xxxx + u_xlat1;\n    u_xlat1 = hlslcc_mtx4x4unity_MatrixVP[2]
            * u_xlat0.zzzz + u_xlat1;\n    gl_Position = hlslcc_mtx4x4unity_MatrixVP[3]
            * u_xlat0.wwww + u_xlat1;\n    vs_TEXCOORD0.xyz = in_POSITION0.xyz;\n   
            u_xlat0.y = (_MirrorOnBack != 0) ? 1.0 : 0.5;\n    u_xlat0.x = 2.0;\n   
            vs_TEXCOORD1.xy = (int(_ImageType) != 0) ? u_xlat0.xy : vec2(1.0, 1.0);\n   
            u_xlati0 = (-unity_StereoEyeIndex) + 1;\n    u_xlat0.y = float(u_xlati0);\n   
            u_xlatb1 = _Layout==1;\n    u_xlat2.x = float(unity_StereoEyeIndex);\n   
            u_xlat2.y = float(0.0);\n    u_xlat2.z = float(0.5);\n    u_xlat2.w =
            float(1.0);\n    u_xlat0.x = float(0.0);\n    u_xlat0.z = float(1.0);\n   
            u_xlat0.w = float(0.5);\n    u_xlat0 = (bool(u_xlatb1)) ? u_xlat2 : u_xlat0;\n   
            vs_TEXCOORD2 = (int(_Layout) != 0) ? u_xlat0 : vec4(0.0, 0.0, 1.0, 1.0);\n   
            return;\n}\n\n"
          FragmentProgram: "\n#version 300 es\n\nprecision highp float;\nprecision
            highp int;\n#define HLSLCC_ENABLE_UNIFORM_BUFFERS 0\n#if HLSLCC_ENABLE_UNIFORM_BUFFERS\n#define
            UNITY_UNIFORM\n#else\n#define UNITY_UNIFORM uniform\n#endif\n#define
            UNITY_SUPPORTS_UNIFORM_LOCATION 0\n#if UNITY_SUPPORTS_UNIFORM_LOCATION\n#define
            UNITY_LOCATION(x) layout(location = x)\n#define UNITY_BINDING(x) layout(binding
            = x, std140)\n#else\n#define UNITY_LOCATION(x)\n#define UNITY_BINDING(x)
            layout(std140)\n#endif\nuniform \tmediump vec4 _MainTex_HDR;\nuniform
            \tmediump vec4 _Tint;\nuniform \tmediump float _Exposure;\nUNITY_LOCATION(0)
            uniform mediump sampler2D _MainTex;\nin highp vec3 vs_TEXCOORD0;\nin
            highp vec2 vs_TEXCOORD1;\nin highp vec4 vs_TEXCOORD2;\nlayout(location
            = 0) out mediump vec4 SV_Target0;\nvec3 u_xlat0;\nmediump vec4 u_xlat16_0;\nvec2
            u_xlat1;\nbool u_xlatb2;\nmediump vec3 u_xlat16_3;\nvec2 u_xlat4;\nbool
            u_xlatb4;\nvec2 u_xlat5;\nbool u_xlatb8;\nbvec2 u_xlatb9;\nfloat u_xlat12;\nbool
            u_xlatb12;\nvoid main()\n{\n    u_xlat0.x = dot(vs_TEXCOORD0.xyz, vs_TEXCOORD0.xyz);\n   
            u_xlat0.x = inversesqrt(u_xlat0.x);\n    u_xlat0.xyz = u_xlat0.xxx *
            vs_TEXCOORD0.yzx;\n    u_xlat12 = -abs(u_xlat0.x) + 1.0;\n    u_xlat12
            = sqrt(u_xlat12);\n    u_xlat1.x = abs(u_xlat0.x) * -0.0187292993 + 0.0742610022;\n   
            u_xlat1.x = u_xlat1.x * abs(u_xlat0.x) + -0.212114394;\n    u_xlat1.x
            = u_xlat1.x * abs(u_xlat0.x) + 1.57072878;\n    u_xlat5.x = u_xlat12
            * u_xlat1.x;\n    u_xlat5.x = u_xlat5.x * -2.0 + 3.14159274;\n    u_xlatb9.xy
            = lessThan(u_xlat0.xzxz, (-u_xlat0.xzxz)).xy;\n    u_xlat0.x = u_xlatb9.x
            ? u_xlat5.x : float(0.0);\n    u_xlat5.y = u_xlat1.x * u_xlat12 + u_xlat0.x;\n   
            u_xlat0.x = min(abs(u_xlat0.z), abs(u_xlat0.y));\n    u_xlat12 = max(abs(u_xlat0.z),
            abs(u_xlat0.y));\n    u_xlat12 = float(1.0) / u_xlat12;\n    u_xlat0.x
            = u_xlat12 * u_xlat0.x;\n    u_xlat12 = u_xlat0.x * u_xlat0.x;\n    u_xlat1.x
            = u_xlat12 * 0.0208350997 + -0.0851330012;\n    u_xlat1.x = u_xlat12
            * u_xlat1.x + 0.180141002;\n    u_xlat1.x = u_xlat12 * u_xlat1.x + -0.330299497;\n   
            u_xlat12 = u_xlat12 * u_xlat1.x + 0.999866009;\n    u_xlat1.x = u_xlat12
            * u_xlat0.x;\n    u_xlatb2 = abs(u_xlat0.z)<abs(u_xlat0.y);\n    u_xlat1.x
            = u_xlat1.x * -2.0 + 1.57079637;\n    u_xlat1.x = u_xlatb2 ? u_xlat1.x
            : float(0.0);\n    u_xlat0.x = u_xlat0.x * u_xlat12 + u_xlat1.x;\n   
            u_xlat12 = u_xlatb9.y ? -3.14159274 : float(0.0);\n    u_xlat0.x = u_xlat12
            + u_xlat0.x;\n    u_xlat12 = min(u_xlat0.z, u_xlat0.y);\n    u_xlat4.x
            = max(u_xlat0.z, u_xlat0.y);\n    u_xlatb8 = u_xlat12<(-u_xlat12);\n   
            u_xlatb4 = u_xlat4.x>=(-u_xlat4.x);\n    u_xlatb4 = u_xlatb4 && u_xlatb8;\n   
            u_xlat5.x = (u_xlatb4) ? (-u_xlat0.x) : u_xlat0.x;\n    u_xlat4.x = 0.5;\n   
            u_xlat4.y = vs_TEXCOORD2.y;\n    u_xlat0.yz = (-u_xlat5.xy) * vec2(0.159154937,
            0.318309873) + u_xlat4.xy;\n    u_xlatb12 = vs_TEXCOORD1.y<u_xlat0.y;\n   
            if(u_xlatb12){\n        SV_Target0 = vec4(0.0, 0.0, 0.0, 1.0);\n       
            return;\n    }\n    u_xlat4.x = u_xlat0.y * vs_TEXCOORD1.x;\n    u_xlatb12
            = u_xlat4.x>=(-u_xlat4.x);\n    u_xlat4.x = fract(abs(u_xlat4.x));\n   
            u_xlat0.x = (u_xlatb12) ? u_xlat4.x : (-u_xlat4.x);\n    u_xlat1.x =
            vs_TEXCOORD2.x;\n    u_xlat1.y = 1.0;\n    u_xlat0.xy = u_xlat0.xz +
            u_xlat1.xy;\n    u_xlat0.xy = u_xlat0.xy * vs_TEXCOORD2.zw;\n    u_xlat16_0
            = texture(_MainTex, u_xlat0.xy);\n    u_xlat16_3.x = u_xlat16_0.w + -1.0;\n   
            u_xlat16_3.x = _MainTex_HDR.w * u_xlat16_3.x + 1.0;\n    u_xlat16_3.x
            = log2(u_xlat16_3.x);\n    u_xlat16_3.x = u_xlat16_3.x * _MainTex_HDR.y;\n   
            u_xlat16_3.x = exp2(u_xlat16_3.x);\n    u_xlat16_3.x = u_xlat16_3.x *
            _MainTex_HDR.x;\n    u_xlat16_3.xyz = u_xlat16_0.xyz * u_xlat16_3.xxx;\n   
            u_xlat16_3.xyz = u_xlat16_3.xyz * _Tint.xyz;\n    u_xlat16_3.xyz = u_xlat16_3.xyz
            * vec3(_Exposure);\n    SV_Target0.xyz = u_xlat16_3.xyz * vec3(4.5947938,
            4.5947938, 4.5947938);\n    SV_Target0.w = 1.0;\n    return;\n}\n\n"
