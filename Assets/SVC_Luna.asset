            * u_xlat16_3.x + 1.0;\n    u_xlat16_3.x = log2(u_xlat16_3.x);\n    u_xlat16_3.x
            = u_xlat16_3.x * unity_SpecCube0_HDR.y;\n    u_xlat16_3.x = exp2(u_xlat16_3.x);\n   
