            u_xlat27;\nfloat u_xlat28;\nmediump float u_xlat16_32;\nvoid main()\n{\n   
            u_xlat0.x = dot(vs_TEXCOORD1.xyz, vs_TEXCOORD1.xyz);\n    u_xlat0.x =
